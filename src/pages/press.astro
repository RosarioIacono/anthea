---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Press" description="Press coverage and media resources for Anthea.">
  <section class="page-hero">
    <div class="section-wrap max-w-3xl">
      <span class="inline-block font-heading text-xs uppercase tracking-widest text-ochre mb-4">Media</span>
      <h1 class="font-heading text-4xl md:text-5xl font-semibold text-linen">Press & Media</h1>
    </div>
  </section>
  <section class="py-20 bg-linen">
    <div class="section-wrap max-w-3xl">
      <div class="reveal prose prose-anthea max-w-none">
        <p>
          For press enquiries, interview requests, or media resources, please contact us at
          <a href="mailto:press@anthea.bio">press@anthea.bio</a>.
        </p>
        <p>
          Anthea has been recognised through the EIT Food Innovator Fellowship and
          the Weinberg Campus accelerator programme. We are happy to speak about
          open-source seed systems, mycorrhizal biotechnology, and the future of
          controlled-environment seedling production.
        </p>
        <h2>Coverage</h2>
        <p class="text-stone/60 italic">
          Press mentions will be listed here as they are published. If you have covered
          Anthea and would like to be included, please get in touch.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
